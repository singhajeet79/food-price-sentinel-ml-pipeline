# Kafka (Aiven)
KAFKA_BOOTSTRAP_SERVERS=food-price-kafka-<your-project>.aivencloud.com:PORT
KAFKA_SECURITY_PROTOCOL=SSL
KAFKA_SSL_CAFILE=certs/ca.pem
KAFKA_SSL_CERTFILE=certs/service.cert
KAFKA_SSL_KEYFILE=certs/service.key

# Topics
KAFKA_TOPIC_FOOD=food-prices
KAFKA_TOPIC_ENERGY=energy-prices
KAFKA_TOPIC_FERTILIZER=fertilizer-supply
KAFKA_TOPIC_ALERTS=price-alerts

# Consumer
KAFKA_CONSUMER_GROUP=food-price-sentinel-processor
KAFKA_AUTO_OFFSET_RESET=latest

# Model
ANOMALY_THRESHOLD=0.65
ROLLING_WINDOW_DAYS=7
LONG_WINDOW_DAYS=30
ENERGY_LAG_DAYS=14
STALE_DATA_THRESHOLD_MINUTES=180
ALERT_COOLDOWN_SECONDS=21600
SEASONAL_LOOKBACK_YEARS=3

# FX
FX_UPDATE_INTERVAL_MINUTES=60
FX_PROVIDER=openexchangerates
FX_API_KEY=<your-fx-api-key>

# Data Sources
SOURCE_PRIORITY_FAO=1
SOURCE_PRIORITY_WORLDBANK=2
SOURCE_PRIORITY_USDA=3

# Valkey / Redis (Aiven)
VALKEY_HOST=sentinel-cache-<your-project>.aivencloud.com
VALKEY_PORT=PORT
VALKEY_PASSWORD=<your-valkey-password>
VALKEY_TLS=true

# PostgreSQL (Aiven)
POSTGRES_URL=postgresql://<user>:<password>@sentinel-db-<your-project>.aivencloud.com:PORT/defaultdb?sslmode=require
